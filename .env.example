# Connexion Postgres (Neon, Supabase, Vercel Postgres…).
# Sans cette variable, l'app utilise un stockage fichier local (dev uniquement).
#
# Utilisez de préférence l'URL de connexion « pooler » de votre fournisseur :
#   - Neon    : l'URL « Pooled connection » (…-pooler.…)
#   - Supabase: le « Connection pooler », port 6543, mode « Transaction »
#
# Exemples :
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL=

# URL publique du site (canonical, Open Graph, sitemap).
# Le blog est servi sous ce domaine, à /blog. En production : https://swipelink.fr
NEXT_PUBLIC_SITE_URL="https://swipelink.fr"

# Aperçu de la concurrence Google (SerpApi) — optionnel.
# Clé API pour afficher les 3 premiers résultats Google d'un mot-clé.
# Offre gratuite sur https://serpapi.com (crée un compte, copie ta clé).
SERPAPI_KEY=

# --- Publication vers le site vitrine (swipelink.fr/blog) ---
# À la publication, l'app génère une page HTML au design du site et la pousse
# dans le repo GitHub du site. Sans ces variables, cette synchro est désactivée
# (la publication interne à l'app continue de fonctionner).
#
# Token GitHub « fine-grained » avec la permission « Contents: Read and write »
# sur le repo du site uniquement.
SITE_GITHUB_TOKEN=
# Repo du site au format "owner/nom".
SITE_REPO="coldcall-swipelink/swipelink"
# Branche cible (défaut : main).
SITE_BRANCH="main"

# Stockage des images uploadées (Vercel Blob).
# Créez un store Blob dans Vercel → Storage : la variable est ajoutée
# automatiquement. Sans elle, les images sont stockées sur le disque local
# (dev uniquement — ne fonctionne pas en serverless).
BLOB_READ_WRITE_TOKEN=
