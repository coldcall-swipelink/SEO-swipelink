# Connexion Postgres (Neon, Supabase, Vercel Postgres…).
# Sans cette variable, l'app utilise un stockage fichier local (dev uniquement).
#
# Utilisez de préférence l'URL de connexion « pooler » de votre fournisseur :
#   - Neon    : l'URL « Pooled connection » (…-pooler.…)
#   - Supabase: le « Connection pooler », port 6543, mode « Transaction »
#
# Exemples :
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL=

# URL publique du site (canonical, Open Graph, sitemap).
NEXT_PUBLIC_SITE_URL="https://votre-domaine.com"
